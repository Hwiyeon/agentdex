{
  "name": "poke-agent-safari",
  "version": "0.2.0",
  "private": true,
  "description": "Dependency-free local watcher + pixel dashboard for Claude Code transcript activity",
  "main": "./index.js",
  "publisher": "hwing",
  "displayName": "Agent Safari",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCommand:pokeAgentSafari.open",
    "onCommand:pokeAgentSafari.openMock",
    "onCommand:pokeAgentSafari.hardReset",
    "onCommand:pokeAgentSafari.downloadAssets"
  ],
  "contributes": {
    "commands": [
      {
        "command": "pokeAgentSafari.open",
        "title": "Agent Safari: Open (Watch)"
      },
      {
        "command": "pokeAgentSafari.openMock",
        "title": "Agent Safari: Open (Mock)"
      },
      {
        "command": "pokeAgentSafari.hardReset",
        "title": "Agent Safari: Hard Reset"
      },
      {
        "command": "pokeAgentSafari.downloadAssets",
        "title": "Agent Safari: Download Sprite Assets"
      }
    ],
    "configuration": {
      "title": "Agent Safari",
      "properties": {
        "pokeAgentSafari.assetMode": {
          "type": "string",
          "enum": [
            "lite",
            "full"
          ],
          "default": "full",
          "description": "Sprite download mode for the VS Code panel."
        },
        "pokeAgentSafari.enablePokeapiSprites": {
          "type": "boolean",
          "default": true
        },
        "pokeAgentSafari.useSprites": {
          "type": "boolean",
          "default": true,
          "description": "Enable downloaded sprite assets in the VS Code panel."
        },
        "pokeAgentSafari.claudeProjectsPath": {
          "type": "string",
          "default": ""
        },
        "pokeAgentSafari.activeTimeoutSec": {
          "type": "number",
          "default": 600
        },
        "pokeAgentSafari.staleTimeoutSec": {
          "type": "number",
          "default": 28800
        }
      }
    }
  },
  "files": [
    "bootstrap.js",
    "claudeSettings.js",
    "configResolver.js",
    "extension/src/**/*.js",
    "extension/README.md",
    "index.js",
    "mockDriver.js",
    "parser.js",
    "paths.js",
    "pokemon.js",
    "public/app.js",
    "public/index.html",
    "public/style.css",
    "snapshotPayload.js",
    "state.js",
    "watcher.js",
    "data/pokemon_data.json",
    "data/pokemon_names_ko.json",
    "data/area_mask.png",
    "data/island_map_cc.png"
  ],
  "scripts": {
    "setup:assets": "node tools/setup_poke_assets.js",
    "watch": "node cli.js watch",
    "mock": "node cli.js mock",
    "test": "node test/claude-code-transcripts.test.js && node test/review-fixes.test.js && node test/pokedex.test.js && node test/setup-scripts.test.js && node test/cli-persistence.test.js && node test/extension-webview-bridge.test.js && node test/extension-html-template.test.js && node test/extension-asset-manager.test.js && node test/shared-snapshot.test.js",
    "package:vsix": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.27.0",
    "ovsx": "^0.8.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hwiyeon/poke-agent-safari.git"
  },
  "homepage": "https://github.com/Hwiyeon/poke-agent-safari",
  "license": "MIT"
}
